{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "FYuoBot 配置",
    "description": ".fyuobot/config.json — Agent 运行时与 MCP 服务器配置",
    "type": "object",
    "properties": {
        "mcpServers": {
            "type": "array",
            "description": "要连接的 MCP 服务器列表",
            "items": {
                "$ref": "#/$defs/mcpServer"
            }
        }
    },
    "$defs": {
        "mcpServer": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "唯一标识名（工具名前缀 mcp_<name>_<tool>）"
                },
                "transport": {
                    "type": "string",
                    "enum": ["stdio", "sse"],
                    "description": "传输方式。未指定时自动推断：有 command → stdio，有 url → sse"
                },
                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否启用，false 时跳过连接"
                },
                "command": {
                    "type": "string",
                    "description": "[stdio] 可执行文件路径"
                },
                "args": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "[stdio] 命令行参数"
                },
                "cwd": {
                    "type": "string",
                    "description": "[stdio] 工作目录"
                },
                "env": {
                    "type": "object",
                    "additionalProperties": { "type": "string" },
                    "description": "[stdio] 环境变量"
                },
                "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "[sse] SSE 端点 URL"
                },
                "headers": {
                    "type": "object",
                    "additionalProperties": { "type": "string" },
                    "description": "[sse] 自定义 HTTP 头（认证令牌等）"
                }
            }
        }
    }
}
