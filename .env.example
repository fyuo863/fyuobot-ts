# 你的第三方 API Key（必填）
THIRD_PARTY_API_KEY=sk-your-api-key-here

# 第三方平台文档中提供的兼容 API 地址
# DeepSeek: https://api.deepseek.com
# OpenAI:  https://api.openai.com/v1 （默认）
# Ollama:  http://127.0.0.1:11434/v1
THIRD_PARTY_BASE_URL=https://api.deepseek.com

# 要调用的默认模型名
# 也可以改用 .fyuobot/config.json 中的 defaultModel + models 模型表来维护多个可选模型
THIRD_PARTY_MODEL=deepseek-v4-flash
